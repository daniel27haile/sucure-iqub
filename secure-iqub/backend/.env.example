# Application
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:4200

# MongoDB
MONGO_URI=mongodb+srv://Ethiopian:Ethiopian@cluster0.fyfw7.mongodb.net/secure-equbDB?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_change_in_production
JWT_REFRESH_EXPIRES_IN=30d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Platform Defaults (can be overridden in DB via PlatformSetting)
DEFAULT_PENALTY_PER_DAY=20
DEFAULT_SLOT_AMOUNT=2000
DEFAULT_CYCLE_LENGTH=12
DEFAULT_PLATFORM_FEE_PERCENT=0

# File Upload (optional, for payment proof)
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
